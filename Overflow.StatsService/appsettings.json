{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FusionCache": {
    "ConnectionStringName": "stat-redis",
    "DurationSeconds": 300,
    "IsFailSafeEnabled": true,
    "FailSafeMaxDurationSeconds": 900,
    "FailSafeThrottleDurationSeconds": 10
  },
  "KeycloakOptions": {
    "Url": "http://localhost:6001",
    "ServiceName": "overflow-service",
    "Realm": "overflow",
    "Audience": "overflow",
    "ValidIssuers": [
      "http://localhost:6001/realms/overflow"
    ]
  },
  "EnvironmentVariables": {
    "Values": {
      "OTEL_SERVICE_NAME": "stats-service"
    }
  }
}