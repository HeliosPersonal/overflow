{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "KeycloakOptions": {
    "Url": "http://localhost:6001",
    "ServiceName": "overflow-service",
    "Realm": "overflow",
    "Audience": "overflow",
    "ValidIssuers": [
      "http://localhost:6001/realms/overflow"
    ]
  },
  "OpenTelemetryOptions": {
    "Endpoint": "http://localhost:4318",
    "ServiceName": "stats-service",
    "Protocol": "grpc",
    "ResourceAttributes": {
      "deployment.environment": "Development"
    }
  }
}