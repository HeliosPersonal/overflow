{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "KeycloakOptions": {
    "Url": "http://keycloak.infra-production.svc.cluster.local:8080",
    "ServiceName": "overflow-staging",
    "Realm": "overflow-staging",
    "Audience": "overflow-staging",
    "ValidIssuers": [
      "http://keycloak.infra-production.svc.cluster.local:8080/realms/overflow-staging",
      "http://keycloak.helios/realms/overflow-staging",
      "http://keycloak.devoverflow.org/realms/overflow-staging"
    ]
  },
  "OpenTelemetryOptions": {
    "Endpoint": "https://otlp-gateway-prod-eu-west-2.grafana.net/otlp",
    "Protocol": "http/protobuf",
    "ServiceName": "stats-service",
    "ResourceAttributes": {
      "deployment.environment": "Staging"
    }
  }
}