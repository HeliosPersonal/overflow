# Don't copy sensitive .env files into Docker image
# But allow environment-specific config files (.env.production, .env.staging)
# Secrets will be provided by Infisical at runtime
.env
.env.local
.env.development
!.env.production
!.env.staging

# Development files
.git
.gitignore
README.md
.vscode
.idea

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js
.next
out

# Testing
coverage
.nyc_output

# Misc
.DS_Store
*.pem

