      "https://keycloak.devoverflow.org/realms/overflow"
    ]
  },
  "EnvironmentVariables": {
    "Values": {
      "PROFILE_SERVICE_URL": "http://profile-svc.apps-production.svc.cluster.local:8080"
    }
  }
