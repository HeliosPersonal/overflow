{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "FusionCache": {
    "ConnectionStringName": "redis"
  },
  "KeycloakOptions": {
