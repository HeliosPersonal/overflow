{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FusionCache": {
    "ConnectionStringName": "estimation-redis",
    "DurationSeconds": 30,
    "IsFailSafeEnabled": true,
    "FailSafeMaxDurationSeconds": 300,
    "FailSafeThrottleDurationSeconds": 5
  },
  "RoomCleanup": {
    "InactiveDaysBeforeArchive": 10,
    "ArchivedDaysBeforeDelete": 10,
    "IntervalHours": 24
  },
  "KeycloakOptions": {
    "Url": "http://localhost:6001",
    "ServiceName": "overflow-service",
    "Realm": "overflow",
    "Audience": "overflow",
    "ValidIssuers": [
      "http://localhost:6001/realms/overflow"
    ]
  },
  "EnvironmentVariables": {
    "Values": {
      "OTEL_SERVICE_NAME": "estimation-service"
    }
  }
}

