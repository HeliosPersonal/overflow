      "OTEL_SERVICE_NAME": "estimation-service",
      "OTEL_EXPORTER_OTLP_ENDPOINT": "http://grafana-alloy.monitoring.svc.cluster.local:4318",
      "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
      "PROFILE_SERVICE_URL": "http://profile-svc.apps-staging.svc.cluster.local:8080"
