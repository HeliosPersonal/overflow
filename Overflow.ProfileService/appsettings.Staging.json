{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "KeycloakOptions": {
    "Url": "https://keycloak.devoverflow.org",
    "ServiceName": "overflow-staging",
    "Realm": "overflow-staging",
    "Audience": "overflow-staging",
    "ValidIssuers": [
      "https://keycloak.devoverflow.org/realms/overflow-staging"
    ]
  },
  "EnvironmentVariables": {
    "Values": {
      "OTEL_SERVICE_NAME": "profile-service",
      "OTEL_EXPORTER_OTLP_ENDPOINT": "https://otlp-gateway-prod-eu-west-2.grafana.net/otlp",
      "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf"
    }
  }
}