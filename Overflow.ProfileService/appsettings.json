{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "KeycloakOptions": {
    "Url": "http://localhost:6001",
    "ServiceName": "overflow-service",
    "Realm": "overflow",
    "Audience": "overflow",
    "ValidIssuers": [
      "http://localhost:6001/realms/overflow"
    ],
    "AdminClientId": "overflow-admin",
    "AdminClientSecret": ""
  },
  "AnonymousCleanup": {
    "GuestAccountMaxAgeDays": 30,
    "IntervalHours": 24
  },
  "EnvironmentVariables": {
    "Values": {
      "OTEL_SERVICE_NAME": "profile-service",
      "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4318",
      "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf"
    }
  }
}