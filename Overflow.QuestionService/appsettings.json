{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FusionCache": {
    "ConnectionStringName": "question-redis",
    "DurationSeconds": 120,
    "IsFailSafeEnabled": true,
    "FailSafeMaxDurationSeconds": 600,
    "FailSafeThrottleDurationSeconds": 10
  },
  "KeycloakOptions": {
    "Url": "http://localhost:6001",
    "ServiceName": "overflow-service",
    "Realm": "overflow",
    "Audience": "overflow",
    "ValidIssuers": [
      "http://localhost:6001/realms/overflow"
    ]
  },
  "EnvironmentVariables": {
    "Values": {
      "OTEL_SERVICE_NAME": "question-service",
      "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4318",
      "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf"
    }
  }
}