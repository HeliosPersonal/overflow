{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "KeycloakOptions": {
    "Url": "http://localhost:6001",
    "ServiceName": "overflow-service",
    "Realm": "overflow",
    "Audience": "overflow",
    "ValidIssuers": [
      "http://localhost:6001/realms/overflow"
    ]
  },
  "TypesenseOptions": {
    "CollectionName": "local_questions"
  },
  "EnvironmentVariables": {
    "Values": {
      "OTEL_SERVICE_NAME": "search-service"
    }
  }
}