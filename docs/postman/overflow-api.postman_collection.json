    {
      "name": "Notifications",
      "description": "Send notifications via NotificationService.\n\nAuth: accepts **either** `X-Api-Key` header (for server-to-server / Postman) **or** Keycloak JWT Bearer token.\n\nSet `{{notification_api_key}}` in your environment, or switch auth to Bearer + `{{access_token}}`.",
      "item": [
        {
          "name": "Send Notification (Password Reset)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Api-Key",
                "value": "{{notification_api_key}}"
