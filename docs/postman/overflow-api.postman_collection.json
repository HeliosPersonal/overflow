            "body": {
              "mode": "raw",
              "raw": "{\n  \"channel\": \"Email\",\n  \"recipient\": \"test@example.com\",\n  \"template\": \"PasswordReset\",\n  \"parameters\": {\n    \"resetUrl\": \"https://staging.devoverflow.org/reset-password?token=test123\",\n    \"appName\": \"Overflow Staging\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/notifications/send",
              "host": [
                "{{base_url}}"
              ],
              "path": [
