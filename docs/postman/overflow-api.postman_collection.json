{
  "info": {
    "name": "Overflow API",
    "description": "Complete API collection for Overflow Q&A platform.\n\n## Setup\n1. Import this collection + both environment files\n2. Select an environment (Staging or Production)\n3. Set `username` and `password` to a valid Keycloak user\n4. Run **Auth \u2192 Get Token** first \u2014 it auto-sets `access_token`\n5. All authenticated requests use `{{access_token}}` automatically\n\nThe `overflow-postman` client is public (no secret needed).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "event": [],
  "item": [
    {
      "name": "Auth",
      "description": "Keycloak token management. Run **Get Token** first to authenticate all other requests.",
      "item": [
        {
          "name": "Get Token (Password Grant)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.environment.set('access_token', json.access_token);",
                  "    console.log('Token set, expires in ' + json.expires_in + 's');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "password"
                },
                {
                  "key": "client_id",
                  "value": "{{client_id}}"
                },
                {
                  "key": "username",
                  "value": "{{username}}"
                },
                {
                  "key": "password",
                  "value": "{{password}}"
                },
                {
                  "key": "scope",
                  "value": "openid profile email offline_access"
                }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/{{realm}}/protocol/openid-connect/token",
              "host": [
                "{{keycloak_url}}"
              ],
              "path": [
                "realms",
                "{{realm}}",
                "protocol",
                "openid-connect",
                "token"
              ]
            }
          }
        },
        {
          "name": "Inspect Token (Decode JWT)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": {
              "raw": "{{keycloak_url}}/realms/{{realm}}/protocol/openid-connect/userinfo",
              "host": [
                "{{keycloak_url}}"
              ],
              "path": [
                "realms",
                "{{realm}}",
                "protocol",
                "openid-connect",
                "userinfo"
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          }
        }
      ]
    },
