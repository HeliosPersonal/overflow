      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Slowest endpoints by p95 latency",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "p95 (s)"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 250
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "gauge"
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-YlRd"
                }
              },
              {
                "id": "unit",
                "value": "s"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "http_route"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "http_request_method"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 29
      },
      "id": 30,
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "p95 (s)"
          }
        ]
      },
      "title": "Slowest Endpoints (p95)",
      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "topk(15, histogram_quantile(0.95, sum by (le, http_route, http_request_method, job, method_route) (label_join(rate(http_server_request_duration_seconds_bucket{job=~\"$service\", http_route!=\"\", http_route!=\"/health\", http_route!=\"/alive\", http_route!=\"/ready\"}[$__rate_interval]), \"method_route\", \" \", \"http_request_method\", \"http_route\"))))",
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "le": true
            },
            "indexByName": {
              "job": 0,
              "method_route": 1,
              "Value": 2
            },
            "renameByName": {
              "Value": "p95 (s)",
              "method_route": "Endpoint",
              "job": "Service"
            }
          }
        }
      ]
    },
