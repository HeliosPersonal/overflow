      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "${DS_TEMPO}"
          },
          "queryType": "traceqlSearch",
          "limit": 30,
          "tableType": "traces",
          "filters": [
            {
              "id": "service-name",
              "tag": "resource.service.name",
              "operator": "=~",
              "value": [
                "$service"
              ],
              "scope": "resource"
            },
            {
              "id": "status",
              "tag": "status",
              "operator": "=",
              "value": [
                "error"
              ],
              "scope": "intrinsic"
