            "lightweight.claim": "false",
            "introspection.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "overflow-staging",
      "name": "Overflow Audience (Staging)",
      "description": "Resource server audience — not a real service. All tokens include this clientId in the 'aud' claim. Backend .NET services validate JWT audience against this value.",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [],
      "webOrigins": [],
      "protocol": "openid-connect",
      "publicClient": true,
